<%- include('partials/header') %>

<main class="flex-grow max-w-6xl mx-auto px-6 py-10">

    <section class="text-center mb-10">
        <h1 class="text-4xl font-bold text-gray-800 mb-2">
            Bem vindo ao site teste MVC com Node.js + Express + EJS de Gabriel Pitta 
        </h1>
        <p class="text-gray-500">
            Gerencie seus produtos de forma simples
        </p>
    </section>

    <section>
        <h2 class="text-2xl font-semibold mb-6 text-gray-700">
            Produtos Cadastrados
        </h2>

        <% if (produtos && produtos.length > 0) { %>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% produtos.forEach(produto => { %>

                    <a href="/produtos/<%= produto.id %>" 
                       class="bg-white rounded-2xl shadow-md p-6 hover:shadow-xl hover:scale-105 transition">

                        <h3 class="text-xl font-bold text-green-600 mb-2">
                            <%= produto.nome %>
                        </h3>

                        <p class="text-gray-600 text-sm mb-3">
                            <%= produto.detalhes %>
                        </p>

                        <p class="text-lg font-semibold text-gray-800">
                            R$ <%= Number(produto.preco).toFixed(2) %>
                        </p>

                    </a>

                <% }) %>
            </div>
        <% } else { %>
            <p class="text-gray-500">Nenhum produto cadastrado</p>
        <% } %>

    </section>

</main>

<%- include('partials/footer') %>