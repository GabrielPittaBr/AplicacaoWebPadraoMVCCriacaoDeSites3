<%- include('partials/header') %>

<main class="flex-grow flex flex-col items-center pt-24 px-6">

    <h1 class="text-3xl font-bold mb-6">Editar Produto</h1>

    <form action="/produtos/edit/<%= produto.id %>" method="POST"
          class="w-full max-w-2xl bg-white p-6 rounded-2xl shadow-md grid gap-4">

        <input type="text" name="nome" value="<%= produto.nome %>" required
            class="border p-3 rounded-lg focus:ring-2 focus:ring-green-500">

        <input type="text" name="detalhes" value="<%= produto.detalhes %>"
            class="border p-3 rounded-lg focus:ring-2 focus:ring-green-500">

        <input type="number" step="0.01" name="preco" value="<%= produto.preco %>" required
            class="border p-3 rounded-lg focus:ring-2 focus:ring-green-500">

        <button class="bg-green-600 text-white py-3 rounded-xl hover:bg-green-700">
            Salvar Alterações
        </button>

    </form>

</main>

<%- include('partials/footer') %>