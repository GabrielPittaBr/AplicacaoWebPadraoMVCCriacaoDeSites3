<%- include('partials/header') %>

    <main class="flex-grow max-w-6xl mx-auto px-6 py-10">

        <h1 class="text-3xl font-bold text-gray-800 mb-8">
            Gerenciar Produtos
        </h1>

        <form action="/produtos" method="POST" class="bg-white p-6 rounded-2xl shadow-md mb-10 grid gap-4 w-full max-w-2xl">

            <input type="text" name="nome" placeholder="Nome do produto" required
                class="border p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">

            <input type="text" name="detalhes" placeholder="Detalhes do produto"
                class="border p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">

            <input type="number" step="0.01" name="preco" placeholder="Preço" required
                class="border p-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500">

            <button type="submit"
                class="bg-green-600 text-white py-3 rounded-xl font-semibold hover:bg-green-700 transition">
                Adicionar Produto
            </button>
        </form>

        <% if (produtos && produtos.length> 0) { %>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

                <% produtos.forEach(produto=> { %>

                    <div class="bg-white rounded-2xl shadow-md p-6 hover:shadow-lg transition">

                        <a href="/produtos/<%= produto.id %>">
                            <h3 class="text-xl font-bold text-green-600 mb-2">
                                <%= produto.nome %>
                            </h3>

                            <p class="text-gray-600 text-sm mb-2">
                                <%= produto.detalhes %>
                            </p>

                            <p class="text-lg font-semibold text-gray-800 mb-4">
                                R$ <%= Number(produto.preco).toFixed(2) %>
                            </p>
                        </a>

                        <div class="flex gap-3 mt-4">

                            <a href="/produtos/edit/<%= produto.id %>"
                                class="bg-yellow-400 text-white px-4 py-2 rounded-lg hover:bg-yellow-500 transition text-sm">
                                Editar
                            </a>

                            <a href="/delete/<%= produto.id %>"
                                onclick="return confirmarExclusao('<%= produto.nome %>')"
                                class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600 transition text-sm">
                                Excluir
                            </a>

                        </div>

                    </div>

                    <% }) %>

            </div>
            <% } else { %>
                <p class="text-gray-500">Nenhum produto cadastrado</p>
                <% } %>

    </main>

    <%- include('partials/footer') %>