<%- include('partials/header') %>

<main class="flex-grow flex items-center justify-center mx-auto px-6 py-12 pt-24">

    <div class="w-full max-w-2xl bg-white shadow-lg rounded-2xl p-8">

        <h2 class="text-3xl font-bold text-green-600 mb-4 break-words">
            <%= produto.nome %>
        </h2>

        <p class="text-gray-600 mb-4 break-words">
            <strong>Detalhes:</strong> <%= produto.detalhes %>
        </p>

        <p class="text-xl font-semibold text-gray-800 mb-6">
            R$ <%= Number(produto.preco).toFixed(2) %>
        </p>

        <p class="text-sm text-gray-400 mb-6">
            ID: <%= produto.id %>
        </p>

        <a href="/produtos" 
           class="inline-block bg-green-600 text-white px-6 py-3 rounded-xl hover:bg-green-700 transition">
           ← Voltar
        </a>

    </div>

</main>

<%- include('partials/footer') %>